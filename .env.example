# =============================================================================
# Environment Configuration
# Recommended: run `bun setup` for interactive configuration
# =============================================================================

# =============================================================================
# REQUIRED - App won't start without these
# =============================================================================

# App Configuration
VITE_APP_URL=http://localhost:3000
VITE_APP_NAME=OpenStory
VITE_CONTACT_EMAIL=hello@example.com
VITE_PRIVACY_EMAIL=privacy@example.com

# Auth (auto-generated by `bun setup`)
BETTER_AUTH_SECRET=

# Database - Cloudflare D1
# No local config needed: `bun dev` runs the worker (Workerd via the
# @cloudflare/vite-plugin), which serves a local Miniflare-backed D1.
# Production D1 is configured in wrangler.jsonc.

# =============================================================================
# WORKFLOWS - Async AI generation runs on Cloudflare Workflows
# No local config needed: `bun dev` runs the worker (Workerd via the
# @cloudflare/vite-plugin), which supplies the workflow bindings.
# =============================================================================

# =============================================================================
# AI SERVICES - Needed for generation features
# =============================================================================

# FAL_KEY=           # https://fal.ai - image & video generation
# OPENROUTER_KEY=    # https://openrouter.ai - LLM access for script analysis
# CEREBRAS_API_KEY=  # https://cerebras.ai - fast inference (optional)
# LETZAI_API_KEY=    # https://letz.ai - alternative image gen (optional)

# =============================================================================
# STORAGE - S3-compatible object storage for generated media
# =============================================================================

# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=my-app-storage
# R2_PUBLIC_STORAGE_DOMAIN=storage.example.com
# R2_PUBLIC_ASSETS_BUCKET=my-app-assets              # Shared across all environments
# VITE_R2_PUBLIC_ASSETS_DOMAIN=assets.example.com     # Same for staging and production

# =============================================================================
# OPTIONAL SERVICES
# =============================================================================

# Redis - real-time progress updates (Upstash REST API)
# UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
# UPSTASH_REDIS_REST_TOKEN=

# Google OAuth - social sign-in (falls back to email OTP if not set)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Email - transactional emails via Resend (logs to console in dev if not set)
# RESEND_API_KEY=
# EMAIL_FROM=noreply@example.com

# Billing - Stripe payments (optional, billing/credits always active)
# STRIPE_SECRET_KEY=               # Enables Stripe checkout and auto-top-up
# STRIPE_WEBHOOK_SECRET=

# BYOK API Key Encryption (required if users bring their own AI keys)
# Generate with: openssl rand -base64 32
# API_KEY_ENCRYPTION_KEY=

# Observability - LLM tracing via Langfuse (optional, gracefully degrades)
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_BASE_URL=https://cloud.langfuse.com
# LANGFUSE_PROMPTS_ENABLED=false  # Set to "true" to fetch prompts from Langfuse API

# Analytics (PostHog) - product analytics, error tracking & LLM observability (optional)
# VITE_PUBLIC_POSTHOG_PROJECT_TOKEN=   # https://us.posthog.com/settings/project
# VITE_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# System admin emails (comma-separated, for gift code management)
# ADMIN_EMAILS=admin@example.com

# AI generation concurrency
# FAL_CONCURRENCY_LIMIT=10
# LLM_CONCURRENCY_LIMIT=5
