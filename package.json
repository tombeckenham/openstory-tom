{
  "name": "openstory",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "imports": {
    "#env": {
      "workerd": "./src/lib/env/cloudflare.ts",
      "default": "./src/lib/env/default.ts"
    },
    "#redis": {
      "workerd": "./src/lib/db/redis-cloudflare.ts",
      "default": "./src/lib/db/redis.ts"
    },
    "#db-client": {
      "workerd": "./src/lib/db/client-d1.ts",
      "e2e": "./src/lib/db/client-local.ts",
      "development": "./src/lib/db/client-local.ts",
      "default": "./src/lib/db/client-web.ts"
    },
    "#storage": {
      "workerd": "./src/lib/storage/storage-cloudflare.ts",
      "default": "./src/lib/storage/storage-s3.ts"
    },
    "#actions/*": {
      "storybook": "./src/app/actions/*/index.mock.ts",
      "default": "./src/app/actions/*/index.ts"
    }
  },
  "scripts": {
    "setup": "npx tsx scripts/setup.ts",
    "setup:prd": "npx tsx scripts/setup.ts --prod",
    "setup:deploy": "npx tsx scripts/setup.ts --deploy",
    "setup:stg": "npx tsx scripts/setup.ts --pr-preview",
    "r2:cors": "bun --bun scripts/set-r2-cors.ts",
    "r2:cors:prd": "bun --bun scripts/set-r2-cors.ts --env=prd",
    "r2:cors:stg": "bun --bun scripts/set-r2-cors.ts --env=stg",
    "r2:cors:dev": "bun --bun scripts/set-r2-cors.ts --env=dev",
    "setup:previews": "bun scripts/generate-style-previews.ts && bun scripts/upload-style-previews-to-r2.ts",
    "setup:system-previews": "bun scripts/generate-system-previews.ts && bun scripts/upload-system-previews-to-r2.ts",
    "upload:prompts": "bun --bun scripts/upload-all-prompts.ts",
    "agent-harness": "bunx --bun github:tombeckenham/agent-harness",
    "dev": "bun run --parallel dev:db stripe:dev qstash:dev",
    "dev:db": "bun --bun --sequential db:migrate:local db:seed:local dev:e2e",
    "dev:e2e": "bun --bun scripts/build-content-collections.ts && bun --bun --preload ./scripts/bun-preload-idle-timeout.ts vite dev",
    "stripe:dev": "source .env.local 2>/dev/null; [ -z \"${STRIPE_SECRET_KEY}\" ] && echo 'Skipping Stripe (no STRIPE_SECRET_KEY)' && exit 0; stripe listen --forward-to localhost:3000/api/billing/webhook --api-key=${STRIPE_SECRET_KEY}",
    "qstash:dev": "docker run -p 8080:8080 public.ecr.aws/upstash/qstash:latest qstash dev",
    "build": "vite build",
    "build:cf": "BUILD_CLOUDFLARE=1 vite build",
    "build:e2e": "BUILD_E2E=1 VITE_APP_URL=http://localhost:3001 VITE_DISABLE_DEVTOOLS=true vite build && bun scripts/patch-bun-idle-timeout.ts",
    "start": "bun --bun run .output/server/index.mjs",
    "preview": "BUILD_CLOUDFLARE=1 VITE_APP_URL=http://localhost:8787 bun run build && BUILD_CLOUDFLARE=1 VITE_APP_URL=http://localhost:8787 wrangler dev",
    "preview:nitro": "vite preview",
    "preview:cloudflare": "BUILD_CLOUDFLARE=1 vite preview",
    "build:bun": "bun run --bun vite build",
    "start:bun": "bun --bun .output/server/index.mjs",
    "lint": "bunx oxlint --type-aware",
    "lint:fix": "bunx oxlint --type-aware --fix",
    "dead-code": "bun --bun knip",
    "dead-code:fix": "bun --bun knip --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint:open": "(bun lint 2>&1; bun typecheck 2>&1) | grep -oE '[^ (\\[]+\\.tsx?' | sort -u | sed 's/\\$/\\\\$/g' | tr '\\n' '\\0' | xargs -0 cursor",
    "typecheck": "tsgo --noEmit",
    "test": "bun test",
    "test:ui": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "test:watch": "bun test --watch",
    "test:e2e": "bun --bun playwright test",
    "test:e2e:ui": "bun --bun playwright test --ui",
    "test:e2e:headed": "bun --bun playwright test --headed",
    "test:e2e:full": "PLAYWRIGHT_FULL_PIPELINE=true bun --bun playwright test full-sequence",
    "test:e2e:full:built": "PLAYWRIGHT_FULL_PIPELINE=true bun run build:e2e && E2E_BUILT=true PLAYWRIGHT_FULL_PIPELINE=true bun --bun playwright test full-sequence",
    "test:e2e:record": "E2E_RECORD=1 bun --bun playwright test",
    "test:e2e:full:record": "E2E_RECORD=1 PLAYWRIGHT_FULL_PIPELINE=true bun --bun playwright test full-sequence",
    "test:e2e:full:record:built": "bun run build:e2e && E2E_BUILT=true E2E_RECORD=1 PLAYWRIGHT_FULL_PIPELINE=true bun --bun playwright test full-sequence",
    "test:e2e:setup": "rm -f test.db && bun --bun drizzle-kit migrate --config=drizzle.config.test.ts && bun --bun scripts/seed.ts --test",
    "auth:generate": "bunx @better-auth/cli generate --config src/lib/auth/cli-config.ts",
    "db:generate": "bun --bun drizzle-kit generate --config=drizzle.config.local.ts",
    "db:migrate": "bun --bun drizzle-kit migrate --config=drizzle.config.local.ts",
    "db:migrate:local": "bun --bun drizzle-kit migrate --config=drizzle.config.local.ts",
    "db:migrate:turso": "bun --bun drizzle-kit migrate --config=drizzle.config.turso.ts",
    "db:migrate:test": "bun --bun drizzle-kit migrate --config=drizzle.config.test.ts",
    "db:studio": "bun drizzle-kit studio --config=drizzle.config.local.ts",
    "db:studio:local": "bun drizzle-kit studio --config=drizzle.config.local.ts",
    "db:studio:test": "bun drizzle-kit studio --config=drizzle.config.test.ts",
    "db:seed:local": "bun --bun scripts/seed.ts --local",
    "db:seed:test": "bun --bun scripts/seed.ts --test",
    "db:seed:d1": "bun --bun scripts/seed.ts --d1",
    "db:check": "bun --bun drizzle-kit check --config=drizzle.config.local.ts",
    "db:push": "bun --bun drizzle-kit push --config=drizzle.config.local.ts",
    "db:check-migrations": "bun --bun scripts/check-migrations.ts",
    "db:check-migrations:all": "bun --bun scripts/check-migrations.ts --all",
    "db:seed": "bun --bun scripts/seed.ts",
    "db:setup": "bun db:migrate && bun db:seed",
    "memory:profile": "bun scripts/memory-profile.ts",
    "memory:watch": "bun scripts/memory-profile.ts --watch",
    "memory:clear": "bun scripts/memory-profile.ts --clear",
    "db:migrate:d1": "bun --bun drizzle-kit migrate --config=drizzle.config.d1.ts",
    "db:push:d1": "bun --bun drizzle-kit push --config=drizzle.config.d1.ts",
    "db:studio:d1": "bun drizzle-kit studio --config=drizzle.config.d1.ts",
    "db:push:local": "bun --bun drizzle-kit push --config=drizzle.config.local.ts",
    "db:setup:local": "bun db:migrate:local && bun db:seed:local",
    "qstash:dev:proxy": "docker run -p 8080:8080 -e HTTP_PROXY=http://host.docker.internal:9090 -e HTTPS_PROXY=http://host.docker.internal:9090 -e NO_PROXY=localhost,127.0.0.1,host.docker.internal -e NODE_TLS_REJECT_UNAUTHORIZED=1 public.ecr.aws/upstash/qstash:latest qstash dev",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "build:analyze": "DEBUG_VISUALIZER=1 vite build && open .output/stats-nitro.html",
    "build:analyze:treeshakeoff": "DEBUG_VISUALIZER=1 DEBUG_TREESHAKE_OFF=1 vite build && open .output/stats-nitro.html",
    "letzai:codegen": "bunx @hey-api/openapi-ts -f src/lib/letzai/letzai-config.ts",
    "motion:codegen": "bun scripts/pull-motion-schemas.ts",
    "doppler:setup": "doppler setup -p openstory -c dev",
    "doppler:pull:dev": "doppler secrets download -p openstory --config=dev --format=env --no-file > .env.local",
    "doppler:pull:dev_test": "doppler secrets download -p openstory --config=dev_test --format=env --no-file > .env.local",
    "doppler:pull:prd": "doppler secrets download -p openstory --config=prd --format=env --no-file > .env.production",
    "doppler:pull:stg": "doppler secrets download -p openstory --config=stg --format=env --no-file > .env.staging",
    "doppler:push:dev": "doppler secrets upload -p openstory --config=dev .env.local",
    "doppler:push:prd": "doppler secrets upload -p openstory --config=prd .env.production",
    "doppler:push:stg": "doppler secrets upload -p openstory --config=stg .env.staging",
    "cf:typegen": "wrangler types",
    "cf:build": "bun --bun run cf:typegen && BUILD_CLOUDFLARE=1 bun --bun run build",
    "cf:dev": "BUILD_CLOUDFLARE=1 wrangler dev",
    "cf:preview": "BUILD_CLOUDFLARE=1 vite preview",
    "cf:deploy:prd": "bun --bun run cf:build && wrangler deploy",
    "knip": "knip"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1047.0",
    "@aws-sdk/s3-request-presigner": "^3.1047.0",
    "@better-auth/passkey": "^1.6.11",
    "@content-collections/core": "0.15.0",
    "@content-collections/vite": "0.3.0",
    "@fal-ai/client": "^1.10.1",
    "@fontsource-variable/geist": "^5.2.8",
    "@langfuse/client": "^5.3.0",
    "@langfuse/otel": "^5.3.0",
    "@libsql/client": "^0.17.3",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/sdk-trace-base": "^2.7.1",
    "@posthog/ai": "^7.18.6",
    "@posthog/react": "^1.9.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-direction": "^1.1.1",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@react-email/render": "^2.0.8",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/ai": "^0.17.0",
    "@tanstack/ai-event-client": "^0.3.1",
    "@tanstack/ai-fal": "^0.7.4",
    "@tanstack/ai-openrouter": "^0.9.0",
    "@tanstack/react-query": "^5.100.10",
    "@tanstack/react-router": "^1.169.2",
    "@tanstack/react-router-ssr-query": "^1.166.12",
    "@tanstack/react-start": "^1.167.65",
    "@tanstack/react-virtual": "^3.13.24",
    "@tanstack/zod-adapter": "^1.166.9",
    "@tiptap/extensions": "^3.23.4",
    "@tiptap/react": "^3.23.4",
    "@tiptap/starter-kit": "^3.23.4",
    "@unpic/react": "^1.0.2",
    "@upstash/qstash": "^2.11.0",
    "@upstash/realtime": "^1.0.3",
    "@upstash/redis": "^1.38.0",
    "@upstash/workflow": "^1.2.1",
    "@videojs/react": "^10.0.0-beta.23",
    "better-auth": "^1.6.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "diff": "^9.0.0",
    "drizzle-kit": "^1.0.0-rc.2-e38a2ba",
    "drizzle-orm": "^1.0.0-rc.2-e38a2ba",
    "drizzle-zod": "^0.8.3",
    "gray-matter": "^4.0.3",
    "html-react-parser": "^6.1.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.16.0",
    "mediabunny": "^1.45.2",
    "mermaid": "^11.15.0",
    "next-themes": "^0.4.6",
    "nitro": "3.0.260429-beta",
    "postcss": "^8.5.14",
    "posthog-js": "^1.373.4",
    "posthog-node": "^5.34.1",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-raw": "^7.0.0",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "resend": "^6.12.3",
    "shiki": "^4.0.2",
    "sonner": "^2.0.7",
    "stripe": "^22.1.1",
    "tailwind-merge": "^3.6.0",
    "tiptap-markdown": "^0.9.0",
    "ulid": "^3.0.2",
    "unified": "^11.0.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cf-wasm/photon": "^0.3.5",
    "@chromatic-com/storybook": "^5.2.1",
    "@clack/prompts": "^1.4.0",
    "@cloudflare/vite-plugin": "^1.37.0",
    "@copilotkit/aimock": "^1.24.1",
    "@faker-js/faker": "^10.4.0",
    "@storybook/addon-a11y": "^10.4.0",
    "@storybook/addon-docs": "^10.4.0",
    "@storybook/addon-onboarding": "^10.4.0",
    "@storybook/addon-themes": "^10.4.0",
    "@storybook/react-vite": "^10.4.0",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/devtools-vite": "^0.7.0",
    "@tanstack/react-ai-devtools": "^0.2.32",
    "@tanstack/react-devtools": "^0.10.5",
    "@tanstack/react-query-devtools": "^5.100.10",
    "@tanstack/react-router-devtools": "^1.166.13",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "1.3.14",
    "@types/diff": "^8.0.0",
    "@types/node": "^25.8.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "^7.0.0-dev.20260514.1",
    "@vitejs/plugin-react": "^6.0.2",
    "chalk": "^5.6.2",
    "knip": "^6.13.1",
    "lefthook": "^2.1.6",
    "msw": "^2.14.6",
    "msw-storybook-addon": "^2.0.7",
    "oxfmt": "0.49.0",
    "oxlint": "^1.64.0",
    "oxlint-tsgolint": "0.22.1",
    "playwright": "^1.60.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "shadcn": "^4.7.0",
    "storybook": "^10.4.0",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "wrangler": "^4.91.0"
  },
  "engines": {
    "bun": ">=1.3.0 < 2",
    "node": ">=24 < 25"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
