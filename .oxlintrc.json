{
  "plugins": [
    "eslint",
    "typescript",
    "unicorn",
    "react",
    "react-perf",
    "jsx-a11y",
    "oxc"
  ],
  "categories": {
    "correctness": "error"
  },
  "ignorePatterns": [
    "**/mockServiceWorker.js",
    "*.gen.ts",
    "src/components/ui/**/*.tsx"
  ],
  "rules": {
    "typescript/no-explicit-any": "error",
    "typescript/consistent-type-assertions": "error",
    "typescript/no-unnecessary-type-assertion": "error",
    "typescript/no-unsafe-type-assertion": "error",
    "typescript/no-non-null-assertion": "error",
    "typescript/no-floating-promises": "error",
    "typescript/no-misused-promises": "error",
    "typescript/await-thenable": "error",
    "typescript/no-unnecessary-condition": "warn",
    "unicorn/prefer-optional-catch-binding": "error",
    "react/rules-of-hooks": "error",
    "no-restricted-imports": [
      "error",
      {
        "paths": [
          {
            "name": "#db-client",
            "message": "Only db/scoped.ts and auth/config.ts may import #db-client"
          },
          {
            "name": "@/lib/db/scoped",
            "importNames": ["createScopedDb"],
            "message": "createScopedDb only allowed in middleware.ts, scoped-workflow.ts, and authorized route handlers. Use context.scopedDb."
          }
        ]
      }
    ]
  },
  "overrides": [
    {
      "files": ["*.test.ts", "*.spec.ts", "*.gen.ts", "*.stories.tsx"],
      "rules": {
        "typescript/no-explicit-any": "warn",
        "typescript/no-floating-promises": "off"
      }
    },
    {
      "files": ["e2e/**/*.ts"],
      "rules": {
        "react/rules-of-hooks": "off"
      }
    },
    {
      "files": [
        "**/db/scoped.ts",
        "**/db/client.ts",
        "**/auth/config.ts",
        "**/functions/middleware.ts",
        "**/workflow/scoped-workflow.ts",
        "**/cron/reconcile-all.ts",
        "**/openrouter/callback.ts"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ]
}
